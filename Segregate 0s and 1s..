class Solution {
  public:
    void segregate0and1(vector<int> &arr) {
        // code here
        int count = 0;
        for(int i=0; i<arr.size(); i++)
        {
            if(arr[i] == 0) count++;
            
            arr[i] = 1;
        }
        
        int i=0;
        while(count--)
        {
            arr[i] =0;
            i++;
        }
        
        
    }
};
