class Solution {
public:
    vector<int> constructList(vector<vector<int>> &queries) {
        int t = 0;
        for(int i = 0;i<queries.size();i++){
            int a = queries[i][0];
            int b = queries[i][1];
            if(a == 1){
                t = t^b; 
            } 
        }
        vector<int> ans;
        ans.push_back(0^t);
        for(int i = 0;i<queries.size();i++){
            int a = queries[i][0];
            int b = queries[i][1];
            if(a == 0){
                ans.push_back(b^t);
            } 
            else{
                t = t^b;
            }
        }
        sort(ans.begin(),ans.end());
        return ans;
    }
};

