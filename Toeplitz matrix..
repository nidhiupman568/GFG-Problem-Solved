class Solution {
  public:
    bool isToeplitz(vector<vector<int>>& mat) {
        // code here
        int n = mat.size(), m = mat[0].size();
        unordered_map<int,int> mp;
        for(int i=0;i<n;i++){
            for(int j=0;j<m;j++){
                int diag = i-j;
                if(mp.find(diag)!=mp.end() && mp[diag]!=mat[i][j]){
                    return false;
                }
                mp[diag] = mat[i][j];
            }
        }
        
        return true;
        
    }
};
