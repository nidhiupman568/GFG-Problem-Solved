class Solution {
public:
    int countCoordinates(vector<vector<int>>& mat) {
        //here we do multi-source BFS.
        int n = mat.size();
        int m = mat[0].size();
        vector<vector<int>> v(n,vector<int>(m,0));
        queue<pair<int,int>> q;
        for(int i = 0;i<m-1;i++){
            q.push({0,i});
            v[0][i]++;
        }
        for(int i = 0;i<n-1;i++){
            q.push({i,0});
            v[i][0]++;
        }
        while(!q.empty()){
            int a = q.front().first;
            int b = q.front().second;
            q.pop();
            if(a+1 < n){
               if(mat[a+1][b] >= mat[a][b] && v[a+1][b] == 0){
                   q.push({a+1,b});
                   v[a+1][b]++;
               }
            }
            if(a-1 >= 0){
               if(mat[a-1][b] >= mat[a][b] && v[a-1][b] == 0){
                   q.push({a-1,b});
                   v[a-1][b]++;
               }
            }
            if(b+1 < m){
               if(mat[a][b+1] >= mat[a][b] && v[a][b+1] == 0){
                   q.push({a,b+1});
                   v[a][b+1]++;
               }
            }
            if(b-1 >= 0){
               if(mat[a][b-1] >= mat[a][b] && v[a][b-1] == 0){
                   q.push({a,b-1});
                   v[a][b-1]++;
               }
            }
        }
        vector<vector<int>> v1(n,vector<int>(m,0));
        for(int i = 1;i<m;i++){
            q.push({n-1,i});
            v1[n-1][i]++;
        }
        for(int i = 1;i<n;i++){
            q.push({i,m-1});
            v1[i][m-1]++;
        }
        while(!q.empty()){
            int a = q.front().first;
            int b = q.front().second;
            q.pop();
            if(a+1 < n){
               if(mat[a+1][b] >= mat[a][b] && v1[a+1][b] == 0){
                   q.push({a+1,b});
                   v1[a+1][b]++;
               }
            }
            if(a-1 >= 0){
               if(mat[a-1][b] >= mat[a][b] && v1[a-1][b] == 0){
                   q.push({a-1,b});
                   v1[a-1][b]++;
               }
            }
            if(b+1 < m){
               if(mat[a][b+1] >= mat[a][b] && v1[a][b+1] == 0){
                   q.push({a,b+1});
                   v1[a][b+1]++;
               }
            }
            if(b-1 >= 0){
               if(mat[a][b-1] >= mat[a][b] && v1[a][b-1] == 0){
                   q.push({a,b-1});
                   v1[a][b-1]++;
               }
            }
        }
        v[0][m-1]++;
        v1[0][m-1]++;
        v[n-1][0]++;
        v1[n-1][0]++;
        vector<vector<int>> v2(n,vector<int>(m,0));
        q.push({0,m-1});
        q.push({n-1,0});
        v2[0][m-1]++;
        v2[n-1][0]++;
        while(!q.empty()){
            int a = q.front().first;
            int b = q.front().second;
            q.pop();
            if(a+1 < n){
               if(mat[a+1][b] >= mat[a][b] && v2[a+1][b] == 0){
                   q.push({a+1,b});
                   v2[a+1][b]++;
               }
            }
            if(a-1 >= 0){
               if(mat[a-1][b] >= mat[a][b] && v2[a-1][b] == 0){
                   q.push({a-1,b});
                   v2[a-1][b]++;
               }
            }
            if(b+1 < m){
               if(mat[a][b+1] >= mat[a][b] && v2[a][b+1] == 0){
                   q.push({a,b+1});
                   v2[a][b+1]++;
               }
            }
            if(b-1 >= 0){
               if(mat[a][b-1] >= mat[a][b] && v2[a][b-1] == 0){
                   q.push({a,b-1});
                   v2[a][b-1]++;
               }
            }
        }
        int cnt = 0;
        for(int i = 0;i<n;i++){
        for(int j = 0;j<m;j++){
            if((v[i][j] > 0 && v1[i][j] > 0) || v2[i][j] > 0){
                cnt++;
            }
        }
        }
        return cnt;
    }
};
