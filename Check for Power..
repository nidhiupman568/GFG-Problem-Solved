class Solution {
public:
    bool isPower(int x, int y) {
        if(y == 1){
            return true;
        }
        if(y < x){
            return false;
        }
        if(x == 1){
            if(y == 1){
                return true;
            }
            else{
                return false;
            }
        }
        while(y > 1){
          int r = y%x;
          if(r != 0){
              return false;
          }
          y = y/x;
        }
        return true;
    }
};

